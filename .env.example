# =============================================================================
# library-service (Java / Spring Boot)
# =============================================================================

# PostgreSQL — library-service
# Host y puerto se refieren a los nombres de contenedor de Docker Compose.
# Solo cambiar si se levanta fuera de Docker.
LIBRARY_DB_HOST=
LIBRARY_DB_PORT=
LIBRARY_DB_NAME=
LIBRARY_DB_USER=
LIBRARY_DB_PASSWORD=<your-library-db-password>

# JWT — clave de firma de tokens. Mínimo 32 caracteres alfanuméricos.
JWT_SECRET=<your-jwt-secret-min-32-chars>
JWT_EXPIRATION_MS=86400000

# URL de loans-service (nombre de contenedor en Docker Compose)
LOANS_SERVICE_URL=http://loans-service:8081

# API key interna compartida entre ambos servicios para endpoints /internal/**
# Debe coincidir exactamente con INTERNAL_API_KEY de loans-service
INTERNAL_API_KEY=<your-internal-api-key>

# Puerto en el que escucha library-service
LIBRARY_SERVICE_PORT=8080

# =============================================================================
# loans-service (Go)
# =============================================================================

# PostgreSQL — loans-service
LOANS_DB_HOST=
LOANS_DB_PORT=
LOANS_DB_NAME=
LOANS_DB_USER=
LOANS_DB_PASSWORD=<your-loans-db-password>

# URL de library-service (nombre de contenedor en Docker Compose)
LIBRARY_SERVICE_URL=http://library-service:8080

# API key interna compartida (debe coincidir con INTERNAL_API_KEY de library-service)
INTERNAL_API_KEY=<your-internal-api-key>

# Puerto en el que escucha loans-service
LOANS_SERVICE_PORT=8081
