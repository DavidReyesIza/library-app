# =============================================================================
# library-service (Java / Spring Boot)
# =============================================================================

# PostgreSQL — library-service
LIBRARY_DB_HOST=postgres-library
LIBRARY_DB_PORT=5432
LIBRARY_DB_NAME=library_db
LIBRARY_DB_USER=library_user
LIBRARY_DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_min_32_chars_long_secret
JWT_EXPIRATION_MS=86400000

# Comunicación con loans-service
LOANS_SERVICE_URL=http://loans-service:8081

# API key compartida para endpoints internos (/internal/**)
INTERNAL_API_KEY=change_me_internal_key

# Puerto de library-service
LIBRARY_SERVICE_PORT=8080

# =============================================================================
# loans-service (Go)
# =============================================================================

# PostgreSQL — loans-service
LOANS_DB_HOST=loans-service-db
LOANS_DB_PORT=5432
LOANS_DB_NAME=loans_db
LOANS_DB_USER=loans_user
LOANS_DB_PASSWORD=change_me

# Comunicación con library-service (para /internal/books/{id}/release)
LIBRARY_SERVICE_URL=http://library-service:8080

# API key compartida para endpoints internos (debe coincidir con INTERNAL_API_KEY)
INTERNAL_API_KEY=change_me_internal_key

# Puerto de loans-service
LOANS_SERVICE_PORT=8081
